# Neon Postgres connection string (used by Python scraper, scorer, cleanup)
# Get it from the Neon dashboard — use the pooled connection string.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Groq (used by scorer)
GROQ_API_KEY=your-groq-api-key

# Job search config (used by scraper as a fallback when no user preferences exist)
JOB_KEYWORDS=software engineer
JOB_LOCATION=Remote
