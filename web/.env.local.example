# Neon Postgres connection string (used by the Next.js API routes)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# Clerk authentication — from the Clerk dashboard (API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Groq (LLM scoring)
GROQ_API_KEY=your-groq-api-key

# SMTP (for daily digest email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com

# Cron auth — set this to any random secret string; the digest route checks it
CRON_SECRET=your-random-secret

# Public app URL (used in digest email links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Playwright tests only ---
# A real Clerk test user's credentials (create one in the Clerk dashboard)
E2E_CLERK_USER_IDENTIFIER=playwright@example.com
E2E_CLERK_USER_PASSWORD=your-test-user-password
