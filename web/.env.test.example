# Copy this file to web/.env.test and fill in your values.
# These are used by Playwright tests — never commit .env.test.

# A test Supabase user (create one via the app's /signup page)
TEST_EMAIL=testuser@example.com
TEST_PASSWORD=your-test-password

# Override the base URL if testing against a deployed environment
# PLAYWRIGHT_BASE_URL=https://your-app.vercel.app
